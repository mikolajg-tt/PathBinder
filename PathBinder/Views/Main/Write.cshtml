@{
	ViewData["Title"] = "Write";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/codemirror.min.css" />
<link rel="stylesheet" href="~/css/write.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/page.css" asp-append-version="true" />
<section>
	<div id="writeAreaHolder">
		<nav>
			<div id="buttonContainer">
				<button id="save" onclick="animateSaving()"><i class="fa-solid fa-floppy-disk"></i>Save</button>
				<button onclick="promptForURL()"><i class="fa-solid fa-globe"></i>Nethys</button>
				<button onclick="promptForHomebrewery()"><i class="fa-solid fa-book"></i>Homebrewery</button>
				<button onclick="promptForFile()"><i class="fa-solid fa-file-import"></i>Foundry</button>
				<button onclick="printDocument()"><i class="fa-solid fa-print"></i>Print</button>
				<button onclick="toggleStyleMenu()"><i class="fa-solid fa-palette"></i>Style Menu</button>
			</div>
			<div class="dropdown">
				<button class="dropdownButton"><i class="fa-solid fa-bars"></i>Elements</button>
				<div class="dropdownContainer hidden">
				</div>
			</div>
		</nav>
		<div id="writeAreaWrapper">
			<div id="writeArea">
			</div>
			<div id="styleMenu" class="style-menu hidden">
			</div>
		</div>
	</div>
	<div class="resizer">
		<button onclick="scrollToPart('editor')"><i class="fa-solid fa-arrow-left"></i></button>
		<button onclick="scrollToPart('preview')"><i class="fa-solid fa-arrow-right"></i></button>
	</div>
	<div id="displayAreaHolder"></div>
</section>
<div id="homebreweryModal" class="modal hidden">
	<div class="modal-content">
		<h2>Paste Homebrewery markdown</h2>
		<textarea id="homebreweryInput"></textarea>
		<div class="modal-actions">
			<button class="cancel" onclick="closeHomebrewery()">Cancel</button>
			<button class="ok" onclick="handleHomebrewery()">OK</button>
		</div>
	</div>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/codemirror.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/mode/markdown/markdown.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/addon/search/searchcursor.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/addon/search/search.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/addon/dialog/dialog.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/addon/search/jump-to-line.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/showdown@2.1.0/dist/showdown.min.js"></script>
<script>
	const defaultStyles = {
		actionColor: 'dark',
		pageNumberOffset: 50,
		pageNumberFlipped: false,
		tocColumns: 2,
		tocDensity: 28,
		tocSpacing: 0,
		tocSectionColor: '#58180D',
		tocSubsectionColor: '#58180D',
		tocTitleColor: '#333333',
		tocDotColor: '#999999',
		tocSectionPageNumColor: '#58180D',
		tocSubsectionPageNumColor: '#58180D',
		tocTitlePageNumColor: '#58180D',
		tocSectionSize: 24,
		tocSubsectionSize: 18,
		tocTitleSize: 12,
		tocSectionPageNumSize: 24,
		tocSubsectionPageNumSize: 18,
		tocTitlePageNumSize: 12
	};
	let fileStyles = { ...defaultStyles };

	function actionTag(name) {
		return fileStyles.actionColor === 'white' ? `{{${name}white}} ` : `{{${name}}} `;
	}

	function markUnsaved() {
		let saveButton = document.getElementById('save');
		saveButton.disabled = false;
		saveButton.innerHTML = '<i class="fa-solid fa-floppy-disk"></i>Save';
	}

	let tocStylesDirty = false;

	function isValidColor(str) {
		const s = new Option().style;
		s.color = str;
		return s.color !== '';
	}

	function toHex(color) {
		const ctx = document.createElement('canvas').getContext('2d');
		ctx.fillStyle = color;
		return ctx.fillStyle;
	}

	function populateStyleMenu() {
		const menu = document.getElementById('styleMenu');
		menu.innerHTML = '';

		// ── Tab bar ──
		const tabBar = document.createElement('div');
		tabBar.className = 'sm-tab-bar';

		const tabDefs = [
			{ id: 'action', label: 'Action Colour', icon: 'fa-palette' },
			{ id: 'pagenums', label: 'Page Numbers', icon: 'fa-hashtag' },
			{ id: 'contents', label: 'Contents Page', icon: 'fa-book-open' }
		];

		const panelContainer = document.createElement('div');
		panelContainer.className = 'sm-panel-container';
		const panelEls = {};

		tabDefs.forEach((def, idx) => {
			const tab = document.createElement('button');
			tab.className = 'sm-tab' + (idx === 0 ? ' active' : '');
			tab.innerHTML = '<i class="fa-solid ' + def.icon + '"></i>' + def.label;
			tab.onclick = () => {
				tabBar.querySelectorAll('.sm-tab').forEach(t => t.classList.remove('active'));
				tab.classList.add('active');
				Object.values(panelEls).forEach(p => p.classList.remove('active'));
				panelEls[def.id].classList.add('active');
			};
			tabBar.appendChild(tab);

			const panel = document.createElement('div');
			panel.className = 'sm-panel' + (idx === 0 ? ' active' : '');
			panelEls[def.id] = panel;
			panelContainer.appendChild(panel);
		});

		menu.appendChild(tabBar);
		menu.appendChild(panelContainer);

		// ── Helpers ──
		function addSectionHeading(container, text) {
			const h = document.createElement('div');
			h.className = 'sm-section-heading';
			h.textContent = text;
			container.appendChild(h);
		}

		function addNumberInput(container, label, key, opts = {}) {
			const { min, max, suffix = '', immediate = true, tocLive = false } = opts;
			const row = document.createElement('div');
			row.className = 'sm-row';
			const lbl = document.createElement('span');
			lbl.className = 'sm-label';
			lbl.textContent = label;
			row.appendChild(lbl);
			const numInput = document.createElement('input');
			numInput.type = 'number';
			numInput.className = 'sm-num';
			if (min !== undefined) numInput.min = min;
			if (max !== undefined) numInput.max = max;
			numInput.value = fileStyles[key];
			numInput.oninput = () => {
				let val = parseInt(numInput.value);
				if (isNaN(val)) return;
				if (min !== undefined) val = Math.max(min, val);
				if (max !== undefined) val = Math.min(max, val);
				fileStyles[key] = val;
				numInput.value = val;
				markUnsaved();
				if (immediate) {
					cachedPageTexts = [];
					displayChange();
				} else {
					tocStylesDirty = true;
					if (tocLive) updateTocLive();
				}
			};
			row.appendChild(numInput);
			container.appendChild(row);
		}

		function addColorInput(container, label, key, opts = {}) {
			const { immediate = true, tocLive = false } = opts;
			const row = document.createElement('div');
			row.className = 'sm-row sm-color-row';
			const lbl = document.createElement('span');
			lbl.className = 'sm-label';
			lbl.textContent = label;
			const controls = document.createElement('div');
			controls.className = 'sm-color-controls';
			const swatch = document.createElement('input');
			swatch.type = 'color';
			swatch.className = 'sm-swatch';
			swatch.value = toHex(fileStyles[key]);
			const textInput = document.createElement('input');
			textInput.type = 'text';
			textInput.className = 'sm-color-text';
			textInput.value = fileStyles[key];
			function applyColor(val) {
				fileStyles[key] = val;
				markUnsaved();
				if (immediate) {
					cachedPageTexts = [];
					displayChange();
				} else {
					tocStylesDirty = true;
					if (tocLive) updateTocLive();
				}
			}
			swatch.oninput = () => {
				textInput.value = swatch.value;
				applyColor(swatch.value);
			};
			textInput.onblur = () => {
				if (isValidColor(textInput.value)) {
					swatch.value = toHex(textInput.value);
					applyColor(textInput.value);
				} else {
					textInput.value = fileStyles[key];
				}
			};
			textInput.onkeydown = (e) => {
				if (e.key === 'Enter') textInput.blur();
			};
			controls.appendChild(swatch);
			controls.appendChild(textInput);
			row.appendChild(lbl);
			row.appendChild(controls);
			container.appendChild(row);
		}

		function addToggle(container, label, key, onChange) {
			const row = document.createElement('label');
			row.className = 'sm-row sm-toggle';
			const lbl = document.createElement('span');
			lbl.className = 'sm-label';
			lbl.textContent = label;
			const track = document.createElement('div');
			track.className = 'sm-switch' + (fileStyles[key] ? ' on' : '');
			const knob = document.createElement('div');
			knob.className = 'sm-switch-knob';
			track.appendChild(knob);
			const hiddenCb = document.createElement('input');
			hiddenCb.type = 'checkbox';
			hiddenCb.checked = fileStyles[key];
			hiddenCb.style.display = 'none';
			hiddenCb.onchange = () => {
				track.classList.toggle('on', hiddenCb.checked);
				onChange(hiddenCb.checked);
			};
			row.appendChild(lbl);
			row.appendChild(hiddenCb);
			row.appendChild(track);
			container.appendChild(row);
		}

		function addSegmentedControl(container, label, options, currentValue, onChange) {
			const row = document.createElement('div');
			row.className = 'sm-row';
			const lbl = document.createElement('span');
			lbl.className = 'sm-label';
			lbl.textContent = label;
			row.appendChild(lbl);
			const seg = document.createElement('div');
			seg.className = 'sm-segmented';
			options.forEach(opt => {
				const btn = document.createElement('button');
				btn.className = 'sm-seg-btn' + (opt.value === currentValue ? ' active' : '');
				btn.textContent = opt.label;
				btn.onclick = () => {
					seg.querySelectorAll('.sm-seg-btn').forEach(b => b.classList.remove('active'));
					btn.classList.add('active');
					onChange(opt.value);
				};
				seg.appendChild(btn);
			});
			row.appendChild(seg);
			container.appendChild(row);
		}

		// ── Action Colour Tab ──
		const actionPanel = panelEls['action'];
		addSegmentedControl(actionPanel, 'Action Color', [
			{ label: 'Dark', value: 'dark' },
			{ label: 'White', value: 'white' }
		], fileStyles.actionColor, (val) => {
			fileStyles.actionColor = val;
			markUnsaved();
		});

		// ── Page Numbers Tab ──
		const pageNumPanel = panelEls['pagenums'];
		addNumberInput(pageNumPanel, 'Offset', 'pageNumberOffset', { min: 0, max: 100, suffix: '%', immediate: true });
		addToggle(pageNumPanel, 'Flip odd/even', 'pageNumberFlipped', (checked) => {
			fileStyles.pageNumberFlipped = checked;
			markUnsaved();
			cachedPageTexts = [];
			displayChange();
		});

		// ── Contents Page Tab ──
		const tocPanel = panelEls['contents'];

		addSectionHeading(tocPanel, 'Layout');
		const layoutGrid = document.createElement('div');
		layoutGrid.className = 'sm-grid sm-grid-3';
		addNumberInput(layoutGrid, 'Columns', 'tocColumns', { immediate: false, tocLive: true });
		addNumberInput(layoutGrid, 'Lines Per Column', 'tocDensity', { immediate: false, tocLive: true });
		addNumberInput(layoutGrid, 'Top Spacing', 'tocSpacing', { immediate: false, tocLive: true });
		tocPanel.appendChild(layoutGrid);

		addSectionHeading(tocPanel, 'Typography');
		const typeGrid = document.createElement('div');
		typeGrid.className = 'sm-grid sm-grid-3';
		addNumberInput(typeGrid, 'Section Font Size', 'tocSectionSize', { suffix: 'px', immediate: false, tocLive: true });
		addNumberInput(typeGrid, 'Subsection Font Size', 'tocSubsectionSize', { suffix: 'px', immediate: false, tocLive: true });
		addNumberInput(typeGrid, 'Title Font Size', 'tocTitleSize', { suffix: 'px', immediate: false, tocLive: true });
		addNumberInput(typeGrid, 'Section Page Number Font Size', 'tocSectionPageNumSize', { suffix: 'px', immediate: false, tocLive: true });
		addNumberInput(typeGrid, 'Subsection Page Number Font Size', 'tocSubsectionPageNumSize', { suffix: 'px', immediate: false, tocLive: true });
		addNumberInput(typeGrid, 'Title Page Number Font Size', 'tocTitlePageNumSize', { suffix: 'px', immediate: false, tocLive: true });
		tocPanel.appendChild(typeGrid);

		addSectionHeading(tocPanel, 'Colors');
		const colorGrid = document.createElement('div');
		colorGrid.className = 'sm-grid sm-grid-4';
		addColorInput(colorGrid, 'Section', 'tocSectionColor', { immediate: false, tocLive: true });
		addColorInput(colorGrid, 'Subsection', 'tocSubsectionColor', { immediate: false, tocLive: true });
		addColorInput(colorGrid, 'Title', 'tocTitleColor', { immediate: false, tocLive: true });
		addColorInput(colorGrid, 'Dots', 'tocDotColor', { immediate: false, tocLive: true });
		addColorInput(colorGrid, 'Section Page Number', 'tocSectionPageNumColor', { immediate: false, tocLive: true });
		addColorInput(colorGrid, 'Subsection Page Number', 'tocSubsectionPageNumColor', { immediate: false, tocLive: true });
		addColorInput(colorGrid, 'Title Page Number', 'tocTitlePageNumColor', { immediate: false, tocLive: true });
		tocPanel.appendChild(colorGrid);
	}

	function toggleStyleMenu() {
		const menu = document.getElementById('styleMenu');
		const wasVisible = !menu.classList.contains('hidden');
		if (!wasVisible) {
			menu.classList.remove('hidden');
			menu.offsetHeight;
			menu.classList.add('visible');
		} else {
			menu.classList.remove('visible');
			menu.addEventListener('transitionend', function handler() {
				menu.removeEventListener('transitionend', handler);
				menu.classList.add('hidden');
			}, { once: true });
			if (tocStylesDirty) {
				tocStylesDirty = false;
				rebuildToc();
				displayChange();
			}
		}
	}

	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') {
			const menu = document.getElementById('styleMenu');
			if (!menu.classList.contains('hidden')) {
				toggleStyleMenu();
			}
		}
	});

	function applyStyles(stylesJson) {
		try {
			const parsed = JSON.parse(stylesJson);
			fileStyles = { ...defaultStyles, ...parsed };
			// Migrate old em-based font sizes to px
			const sizeKeys = ['tocSectionSize', 'tocSubsectionSize', 'tocTitleSize', 'tocSectionPageNumSize', 'tocSubsectionPageNumSize', 'tocTitlePageNumSize'];
			for (const k of sizeKeys) {
				if (fileStyles[k] < 8) fileStyles[k] = defaultStyles[k];
			}
			// Migrate old single tocPageNumColor to per-level colors
			if (parsed.tocPageNumColor && !parsed.tocSectionPageNumColor) {
				fileStyles.tocSectionPageNumColor = parsed.tocPageNumColor;
				fileStyles.tocSubsectionPageNumColor = parsed.tocPageNumColor;
				fileStyles.tocTitlePageNumColor = parsed.tocPageNumColor;
			}
			delete fileStyles.tocPageNumColor;
		} catch {
			fileStyles = { ...defaultStyles };
		}
		populateStyleMenu();
	}

	const DEFAULT_FRAME = 'https://i.imgur.com/s75LEm3.png';

	function getCreditsPage(title) {
		return `{{frame ${DEFAULT_FRAME}[mask-image=none, class=base, column-gap=27px]}}
# Credits
{{paragraph **Some artwork © Dean Spencer, used with permission. All rights reserved.**}}
{{line **Some artwork copyright Murzabaev Roman aka s0ulafein,**}}
{{line **used with permission.**}}
{{line **Maps by Snowy's Maps**}}
{{line **Music by RPG Music Maker**}}
{{line **Writing by Snowy's Maps**}}
{{linebreak}}
{{paragraph ${title} ©  ${new Date().getFullYear()}, Snowy's Maps. All rights reserved. Paizo, the Paizo golem, Pathfinder, Starfinder, and other trademarks owned by Paizo are property of Paizo Inc. This work is published under the Community Content Agreement for Pathfinder Infinite and Starfinder Infinite.[font-size=10.5px]}}`.trim();
	}

		const paragraphElements = {
			"image": { "html": "img", "classes": ["image"] },
			"frame": { "html": "img" },
			"title": { "html": "h1", "classes": ["wide", "title"] },
			"section": { "html": "h1", "classes": ["wide", "title"] },
			"subsection": { "html": "h1", "classes": ["wide", "title"] },
			"contents": { "special": true },
			"header": { "html": "header", "classes": ["wide", "subtitle"] },
			"line": { "html": "p", "classes": ["line"] },
			"paragraph": { "html": "p", "classes": ["paragraph"] },
			"linebreak": { "html": "div", "classes": ["linebreak"], "special": true },
			"columnbreak": { "html": "div", "classes": ["break"], "special": true },
			"pagebreak": {"special": true},
			"passivewhite": { "html": "img", "src": "../assets/passive-white.png", "classes": ["action", "oneaction"] },
			"freeactionwhite": { "html": "img", "src": "../assets/freeaction-white.png", "classes": ["action", "oneaction"] },
			"oneactionwhite": { "html": "img", "src": "../assets/oneaction-white.png", "classes": ["action", "oneaction"] },
			"twoactionwhite": { "html": "img", "src": "../assets/twoaction-white.png", "classes": ["action", "twoaction"] },
			"threeactionwhite": { "html": "img", "src": "../assets/threeaction-white.png", "classes": ["action", "threeaction"] },
			"reactionwhite": { "html": "img", "src": "../assets/reaction-white.png", "classes": ["action", "oneaction"] },
			"passive": { "html": "img", "src": "../assets/passive.png", "classes": ["action", "oneaction"] },
			"freeaction": { "html": "img", "src": "../assets/freeaction.png", "classes": ["action", "oneaction"] },
			"oneaction": { "html": "img", "src": "../assets/oneaction.png", "classes": ["action", "oneaction"] },
			"twoaction": { "html": "img", "src": "../assets/twoaction.png", "classes": ["action", "twoaction"] },
			"threeaction": { "html": "img", "src": "../assets/threeaction.png", "classes": ["action", "threeaction"] },
			"reaction": { "html": "img", "src": "../assets/reaction.png", "classes": ["action", "oneaction"] },
			"tag": { "html": "div", "classes": ["tag"] },
			"label": { "html": "div", "classes": ["label"] },
			"artist": { "html": "div", "classes": ["artist"] },
			"table": { "html": "table", "classes": ["table"] },
			"dc": {"html": "span"},
			"mask": {"html": "div"},
			"shape": {"html": "div"},
			"pagenumber":{"html": "p", "classes": ["paragraph"]}
		}
		const dcs = {
			0: 14, 1: 15, 2: 16, 3: 18, 4: 19, 5: 20, 6: 22, 7: 23, 8: 24, 9: 26,
			10: 27, 11: 28, 12: 30, 13: 31, 14: 32, 15: 34, 16: 35, 17: 36, 18: 38,
			19: 39, 20: 40, 21: 42, 22: 44, 23: 46, 24: 48, 25: 50,

			untrained: 10,
			trained: 15,
			expert: 20,
			master: 30,
			legendary: 40
		};

		const MM_TO_PX   = 96 / 25.4;     
		const PAGE_W_MM  = 210;            
		const PAGE_H_MM  = 297;

		const PAGE_W_PX  = PAGE_W_MM * MM_TO_PX;  
		const PAGE_H_PX  = PAGE_H_MM * MM_TO_PX;

		const documentId = window.location.pathname.split('/').filter(Boolean).pop();

		$("#displayAreaHolder").on("scroll", function () {
			localStorage.setItem("PathBinder-Scroll", $("#displayAreaHolder").scrollTop());
		});
		CodeMirror.defineMode("mustacheHighlight", function (config, parserConfig) {
			return {
				token: function (stream, state) {
					if (stream.match("{{") || stream.match("}}")) {
						return "mustache-brackets";
					}

					if (stream.match(/^#/) || stream.match(/^\*/)) {
						return "mustache-markdown";
					}

					if (stream.match("pagebreak")) {
						return "mustache-pagebreak";
					}

					if (stream.string.charAt(stream.start - 2) === '{' || stream.string.charAt(stream.start - 4) === '{') {
						if (stream.match(/^[^\s{}]+/)) {
							return "mustache-firstWord";
						}
					}

					stream.next();
					return null;
				}
			};
		});
		const editor = CodeMirror(document.getElementById("writeArea"), {
			lineNumbers: true,
			lineWrapping: true,
			styleActiveLine: true,
			matchBrackets: true,
			theme: "default",
			mode: "mustacheHighlight",
			scrollbarStyle: "native",
			extraKeys: {
				"Ctrl-F": "findPersistent",
				"Shift-Enter": "findPrev",
				"Esc": "clearSearch",
				"Enter": function (cm) {
					if (cm?.state?.search?.query) {
						cm.execCommand("findNext");
					} else {
						cm.replaceSelection("\n", "end");
					}
				},
				"Ctrl-B": function (cm) {
					toggleWrapSelection(cm, "**");
				},
				"Ctrl-I": function (cm) {
					toggleWrapSelection(cm, "*");
				}
			}
		});
		editor.addOverlay({ name: "mustacheHighlight" });
		let autosaveTimeout;
		let renderFrame;
		let cachedPageTexts = [];
		const displayArea = document.getElementById("displayAreaHolder");
		const converter = new showdown.Converter();
		const shadow = displayArea.attachShadow({ mode: "open" });
		const styleSheet = [...document.styleSheets].find(s => s.href?.includes('/css/page.css'));
		const pageStyle = document.createElement('style');
		pageStyle.textContent = [...styleSheet.cssRules].map(rule => rule.cssText).join('\n');
		shadow.appendChild(pageStyle);
		const tocDynamicStyle = document.createElement('style');
		shadow.appendChild(tocDynamicStyle);
		editor.on('change', function () {
			if (autosaveTimeout) {
				clearTimeout(autosaveTimeout);
			}
			let saveButton = document.getElementById('save');
			saveButton.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save';
			saveButton.disabled = false;
			autosaveTimeout = setTimeout(animateSaving, 5000);
			if (renderFrame) cancelAnimationFrame(renderFrame);
			renderFrame = requestAnimationFrame(() => {
				displayChange();
				$("#displayAreaHolder").scrollTop(localStorage.getItem("PathBinder-Scroll"));
			});
		});

		function toggleWrapSelection(cm, wrapper) {
			const selection = cm.getSelection();
			const cursorPosFrom = cm.getCursor("from");
			const cursorPosTo = cm.getCursor("to");

			const isWrapped = selection.startsWith(wrapper) && selection.endsWith(wrapper);

			if (isWrapped) {
				const unwrappedSelection = selection.slice(wrapper.length, -wrapper.length);
				cm.replaceSelection(unwrappedSelection);
				cm.setSelection(
					{ line: cursorPosFrom.line, ch: cursorPosFrom.ch },
					{ line: cursorPosTo.line, ch: cursorPosTo.ch - 2 * wrapper.length }
				);
			} else {
				cm.replaceSelection(wrapper + selection + wrapper);
				cm.setSelection(
					{ line: cursorPosFrom.line, ch: cursorPosFrom.ch },
					{ line: cursorPosTo.line, ch: cursorPosTo.ch + 2 * wrapper.length }
				);
			}
		}

		function cleanContent(html) {
			const parser = new DOMParser();
			const doc = parser.parseFromString(html, 'text/html');

			const allElements = doc.querySelectorAll('*');
			allElements.forEach(element => {
				const firstChild = element.firstChild;
				if (firstChild && firstChild.nodeType === Node.TEXT_NODE && !firstChild.textContent.trim()) {
					element.remove();
				}
			});

			const actionSpans = doc.querySelectorAll('span[class*="action"]');
			actionSpans.forEach(span => {
				let content = span.textContent.trim();
				content = content.replace(/[-\[\]]/g, '');

				if (content.endsWith('s')) {
					content = content.slice(0, -1);
				}
				const replacementText = `{{${content}}}`;

				const textNode = document.createTextNode(replacementText);
				span.parentNode.replaceChild(textNode, span);
			});

			const anchors = doc.querySelectorAll('a');
			anchors.forEach(anchor => {
				const text = document.createTextNode(anchor.textContent);
				anchor.parentNode.replaceChild(text, anchor);
			})

			const bElements = doc.querySelectorAll('b');
			bElements.forEach(b => {
				const content = b.textContent.trim();

				const replacementText = `**${content}** `;

				const textNode = document.createTextNode(replacementText);
				b.parentNode.replaceChild(textNode, b);
			});

			const h1Elements = doc.querySelectorAll('h1');
			h1Elements.forEach(h1 => {
				const firstChildContent = h1.childNodes[0] ? h1.childNodes[0].textContent.trim() : '';
				const secondChildContent = h1.childNodes[1] ? h1.childNodes[1].textContent.trim() : '';

				const replacementText = `#### ${firstChildContent} {{label ${secondChildContent}}}\n`;

				const textNode = document.createTextNode(replacementText);
				h1.parentNode.replaceChild(textNode, h1);
			});



			const spanWithTagClass = doc.querySelectorAll('span[class*="trait"]');
			spanWithTagClass.forEach(span => {
				const content = span.textContent.trim();

				const replacementText = `{{tag ${content}}}\n`;

				const textNode = document.createTextNode(replacementText);
				span.parentNode.replaceChild(textNode, span);
			});

			const spans = doc.querySelectorAll('span');
			spans.forEach(span => {
				const content = span.innerHTML.trim();
				const replacementHTML = `<br>${content}`;
				span.outerHTML = replacementHTML;
			});

			const hrElements = doc.querySelectorAll('hr');
			hrElements.forEach(hr => {
				const replacementHTML = '<br>{{linebreak}}<br>';
				hr.outerHTML = replacementHTML;
			});

			const brElements = Array.from(doc.querySelectorAll('br'));

			brElements.forEach((br, index) => {
				if (index < brElements.length) {
					const nextBr = brElements[index + 1];
					let contentNodes = [];
					let currentNode = br.nextSibling;
					while (currentNode && currentNode !== nextBr) {
						contentNodes.push(currentNode);
						currentNode = currentNode.nextSibling;
					}
					const content = contentNodes.map(node => node.textContent).join('').trim();
					if (content) {
						const replacement = document.createTextNode(`{{line ${content}}}\n`);
						doc.body.insertBefore(replacement, br);
						contentNodes.forEach(node => node.remove());
					}
				}
				br.remove();
			});

			let content = doc.body.innerHTML;

			while (content.includes('{{line {{linebreak}}}}')) {
				content = content.replace('{{line {{linebreak}}}}', '{{linebreak}}');
			}

			doc.body.innerHTML = content;

			return doc.body.innerHTML;
		}

		function extractContent(content) {
			const titleElements = content.querySelectorAll('h1');
			const secondTitle = titleElements[1] === undefined ? titleElements[0] : titleElements[1];
			let currentNode = secondTitle.nextSibling;
			let extractedContent = secondTitle.outerHTML;
			while (currentNode) {
				if (currentNode.tagName === "H3") {
					const isLegacyContent = currentNode.textContent.toLowerCase().includes("legacy content");
					if (isLegacyContent) {
						currentNode = currentNode.nextSibling;
						continue;
					}
					else {
						break;
					}
				}
				else if (["H1", "H2", "H4", "H5", "H6"].includes(currentNode.tagName) || !currentNode.nextSibling) {
					break;
				}
				extractedContent += currentNode.outerHTML ? currentNode.outerHTML : currentNode.textContent;
				currentNode = currentNode.nextSibling;
			}

			return cleanContent(extractedContent);
		}

		function replaceContent(content) {
			const cursorPosition = editor.getCursor();
			editor.replaceRange(content, cursorPosition);
		}

		async function processURL(url) {
			const serverEndpoint = '@Url.Action("PostImport", "Import")';
			const localStorageKey = `archive-${url}`;
			const parser = new DOMParser();

			let content = localStorage.getItem(localStorageKey);
			if (content) {
				content = parser.parseFromString(content, 'text/html');
			}
			else {
				try {
					const response = await fetch(serverEndpoint, {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json'
						},
						body: JSON.stringify({ Url: url })
					});

					if (!response.ok) {
						throw new Error('Network response was not ok');
					}

					let data = await response.text();
					data = parser.parseFromString(data, 'text/html');
					let element = data.getElementById('ctl00_RadDrawer1_Content_MainContent_DetailedOutput');
					localStorage.setItem(localStorageKey, element.innerHTML);
					content = element;
				} catch (error) {
					console.error('There was a problem with the fetch operation:', error.message);
				}
			}
			content = extractContent(content);
			replaceContent(content);

		}

		function promptForURL() {
			const url = prompt("Please enter a URL from Archives of Nethys:");
			if (url) {
				processURL(url);
			}
		}

		function processJsonData(creatureData) {
			const output = [];
			const sizeMappings = {
				tiny: "Tiny",
				sm: "Small",
				med: "Medium",
				lg: "Large",
				huge: "Huge",
				grg: "Gargantuan"
			};

			const addOutput = (result) => {
				if (Array.isArray(result)) {
					output.push(...result.filter(Boolean));
				} else if (result) {
					output.push(result);
				}
			};

			addOutput(formatCreatureLabel(creatureData));
			addOutput(formatRarity(creatureData));
			addOutput(formatSize(creatureData, sizeMappings));
			addOutput(formatTraits(creatureData));
			addOutput(formatPerception(creatureData));
			addOutput(formatLanguages(creatureData));
			addOutput(formatSkills(creatureData));
			addOutput(formatAbilities(creatureData));
			addOutput(formatItems(creatureData));
			addOutput(formatLinebreak());
			addOutput(formatDefenses(creatureData));
			addOutput(formatHP(creatureData));
			addOutput(formatHardness(creatureData));
			addOutput(formatResistances(creatureData));
			addOutput(formatImmunities(creatureData));
			addOutput(formatWeaknesses(creatureData));
			addOutput(formatReactions(creatureData));
			addOutput(formatLinebreak());
			addOutput(formatSpeeds(creatureData));
			const strikes = formatStrikes(creatureData);
			addOutput(strikes.melee);
			addOutput(strikes.ranged);
			addOutput(formatSpellcasting(creatureData));
			addOutput(formatActions(creatureData));
			return output.join('\n');
		}

		function formatCreatureLabel(creatureData) {
			return `#### ${creatureData.name} {{label Creature ${creatureData.system.details.level.value}}}`;
		}

		function formatTraits(creatureData) {
			return creatureData.system.traits.value.map(trait => `{{tag ${capitalizeFirstLetter(trait)}}}`);
		}

		function formatRarity(creatureData) {
			const rarityValue = creatureData.system.traits.rarity;
			return rarityValue && rarityValue != 'common' ? `{{tag ${capitalizeFirstLetter(rarityValue)}[class=${rarityValue}]}}` : '';
		}

		function formatSize(creatureData, sizeMappings) {
			const sizeValue = creatureData.system.traits.size.value;
			return sizeValue ? `{{tag ${sizeMappings[sizeValue]}[class=size]}}` : '';
		}

		function formatPerception(creatureData) {
			const senses = creatureData.system.perception.senses.map(sense => {
				let formattedSense = sense.type;
				if (sense.acuity) {
					formattedSense += ` (${sense.acuity})`;
				}
				if (sense.range) {
					formattedSense += ` ${sense.range} feet`;
				}
				return formattedSense;
			}).join(', ');

			return `{{line **Perception** +${creatureData.system.perception.mod}; ${senses}}}`;
		}

		function formatLanguages(creatureData) {
			const langData = creatureData.system.details.languages;
			const parts = [];
			if (langData.value.length) parts.push(langData.value.map(l => capitalizeFirstLetter(l)).join(', '));
			if (langData.details) parts.push(langData.details);
			const languages = parts.join('; ');
			if (languages) {
				return `{{line **Languages**  ${languages}}}`;
			}
			return '';
		}

		function formatSkills(creatureData) {
			const capitalizeWords = (str) => str.replace(/\b\w/g, char => char.toUpperCase());
			const skills = Object.entries(creatureData.system.skills).map(([name, data]) => `${capitalizeWords(name)} +${data.base}`).join(', ');
			return skills ? `{{line **Skills**  ${skills}}}` : '';
		}

		function formatAbilities(creatureData) {
			const { str, dex, con, int, wis, cha } = creatureData.system.abilities;
			return `{{line **Str**  ${formatBonus(str.mod)}, **Dex**  ${formatBonus(dex.mod)}, **Con**  ${formatBonus(con.mod)}, **Int**  ${formatBonus(int.mod)}, **Wis**  ${formatBonus(wis.mod)}, **Cha**  ${formatBonus(cha.mod)}}}`;
		}

		function formatItems(creatureData) {
			return creatureData.items.filter(item => ['weapon', 'armor'].includes(item.type))
				.map(item => `{{line **Items**  ${item.name}}}`);
		}

		function formatLinebreak() {
			return '{{linebreak}}';
		}

		function formatDefenses(creatureData) {
			return `{{line **AC**  ${creatureData.system.attributes.ac.value}; **Fort**  +${creatureData.system.saves.fortitude.value}, **Ref**  +${creatureData.system.saves.reflex.value}, **Will**  +${creatureData.system.saves.will.value}}}`;
		}

		function formatHP(creatureData) {
			return `{{line **HP**  ${creatureData.system.attributes.hp.value}}}`;
		}

		function formatHardness(creatureData) {
			let hardness = creatureData?.system?.attributes?.hardness?.value;
			if (hardness) {
				return `{{line **Hardness**  ${hardness}}}`
			}
			return '';
		}

		function formatSpeeds(creatureData) {
			const speeds = creatureData.system.attributes.speed?.otherSpeeds.map(speed => `${speed.type} ${speed.value} feet`).join(', ');
			return `{{line **Speed** ${creatureData.system.attributes.speed.value} feet` + (speeds ? `, ${speeds}` : '') + '}}';
		}

		function formatStringWithHyphen(str) {
			return str.includes('-') ? str.split('-').join(' ') : str;
		}

		function formatResistances(creatureData) {
			const resistances = creatureData.system.attributes?.resistances?.map(resistance => {
				const type = formatStringWithHyphen(resistance.type);
				const exceptions = resistance.exceptions && resistance.exceptions.length > 0 ? ` (except ${resistance.exceptions.map(formatStringWithHyphen).join(', ')})` : '';
				return `${type}${resistance.value ? ` ${resistance.value}` : ''}${exceptions}`;
			}).join('; ');
			return resistances ? `{{line **Resistances**  ${resistances}}}` : '';
		}

		function formatImmunities(creatureData) {
			const immunities = creatureData.system.attributes?.immunities?.map(immunity => formatStringWithHyphen(immunity.type)).join(', ');
			return immunities ? `{{line **Immunities**  ${immunities}}}` : '';
		}

		function formatWeaknesses(creatureData) {
			const weaknesses = creatureData.system.attributes?.weaknesses?.map(weakness => {
				const type = formatStringWithHyphen(weakness.type);
				return `${type} ${weakness.value}`;
			}).join('; ');
			return weaknesses ? `{{line **Weaknesses**  ${weaknesses}}}` : '';
		}

		function formatStrikes(creatureData) {
			const strikes = creatureData.items
				.filter(item => item.type === 'melee')
				.map(melee => formatCombat(melee, false));

			const melee = strikes.filter(s => !s.isRanged).sort((a, b) => a.name.localeCompare(b.name)).map(s => s.text);
			const ranged = strikes.filter(s => s.isRanged).sort((a, b) => a.name.localeCompare(b.name)).map(s => s.text);
			return { melee, ranged };
		}

		function formatReactions(creatureData) {
			const actionSymbols = {
				action: actionTag('oneaction'),
				free: actionTag('freeaction'),
				reaction: actionTag('reaction'),
				passive: ""
			};

			return creatureData.items
				.filter(item => item.type === 'action' && item.system.actionType.value === 'reaction')
				.map(action => {
					const actionSymbol = getActionSymbol(action, actionSymbols);
					return { action, symbol: actionSymbol, name: action.name };
				})
				.sort((a, b) => a.name.localeCompare(b.name))
				.map(({ action, symbol }) => {
					return formatActionText(action, symbol);
				});
		}

		function formatActions(creatureData) {
			const actionSymbols = {
				action: actionTag('oneaction'),
				free: actionTag('freeaction'),
				reaction: actionTag('reaction'),
				passive: ""
			};

			const actionOrder = {
				'freeaction': 0,
				'oneaction': 1,
				'twoaction': 2,
				'threeaction': 3,
				'passive': 4
			};

			const actionCountNames = { 1: 'oneaction', 2: 'twoaction', 3: 'threeaction' };

			function getOrderKey(item) {
				if (item.system.actionType.value === 'free') return 'freeaction';
				if (item.system.actionType.value === 'passive') return 'passive';
				if (item.system.actionType.value === 'action') {
					const count = item.system.actions.value || 1;
					return actionCountNames[count] || 'oneaction';
				}
				return 'passive';
			}

			return creatureData.items
				.filter(item => item.type === 'action' && item.system.actionType.value !== 'reaction')
				.map(action => {
					const actionSymbol = getActionSymbol(action, actionSymbols);
					return {
						action,
						symbol: actionSymbol,
						orderKey: getOrderKey(action),
						name: action.name
					};
				})
				.sort((a, b) => {
					const orderDiff = (actionOrder[a.orderKey] ?? 5) - (actionOrder[b.orderKey] ?? 5);
					return orderDiff !== 0 ? orderDiff : a.name.localeCompare(b.name);
				})
				.map(({ action, symbol }) => {
					return formatActionText(action, symbol);
				});
		}

		function formatSpellcasting(creatureData) {
			const spellcastingEntries = creatureData.items.filter(item => item.type === 'spellcastingEntry');
			return spellcastingEntries.map(entry => {
				let spells = creatureData.items.filter(item => item.type === 'spell').sort((a, b) => a.name.localeCompare(b.name));
				let maxLevel = Math.max(...spells.map(spell => spell.system.level.value || 0));
				let groupedSpells = {};
				spells.forEach(spell => {
					let level = spell.system.traits.value.includes('cantrip') ? (maxLevel + 1) : spell.system.location.heightenedLevel || spell.system.level.value;
					if (!groupedSpells[level]) groupedSpells[level] = [];
					groupedSpells[level].push(spell);
				});
				let sortedLevels = Object.keys(groupedSpells).sort((a, b) => b - a);
				let suffixes = { 1: 'st', 2: 'nd', 3: 'rd' };
				let getSuffix = level => suffixes[level] || 'th';
				let formattedSpells = sortedLevels.filter(level => level <= maxLevel).map(level => {
					let spellsAtLevel = groupedSpells[level].map(spell => {
						let usesMax = spell.system.location.uses?.max;
						return `${spell.name}${usesMax ? ` (x${usesMax})` : ''}`;
					}).join(', ');

					return `**${level}${getSuffix(level)}** ${spellsAtLevel}`;
				}).join(' ');
				if (groupedSpells[maxLevel + 1]) {
					let cantrips = groupedSpells[maxLevel + 1].map(spell => {
						let usesMax = spell.system.location.uses?.max;
						return `${spell.name}${usesMax ? ` (x${usesMax})` : ''}`;
					}).join(', ');

					formattedSpells += ` **Cantrips (${maxLevel}${getSuffix(maxLevel)})** ${cantrips}`;
				}
				const spellDC = entry.system.spelldc;
				const name = 'Spells';
				const tradition = capitalizeFirstLetter(entry.system.tradition.value);
				const spellcastingType = capitalizeFirstLetter(entry.system.prepared.value);
				const spellInfo = `**${tradition} ${spellcastingType} Spells** DC ${ spellDC.dc }, attack +${ spellDC.value }; `;
				return `{{line ${spellInfo} ${formattedSpells}}}`
			})
		}

		function capitalizeFirstLetter(string) {
			return string.charAt(0).toUpperCase() + string.slice(1);
		}

		function formatCombat(combatItem, isRanged) {
			const dmgRolls = Object.values(combatItem.system.damageRolls);
			isRanged = false;

			const traitsList = combatItem.system.traits.value.map(trait => {
				let t = trait.includes('-') ? trait.split('-').join(' ') : trait;
				return t;
			});

			const range = combatItem.system.range;
			if (range && typeof range === 'object') {
				if (range.increment) {
					isRanged = true;
					traitsList.push(`range increment ${range.increment} feet`);
				} else if (range.max) {
					isRanged = true;
					traitsList.push(`range ${range.max} feet`);
				}
			}
			const traits = traitsList.length ? ` \\(${traitsList.join(", ")})` : "";

			const attackEffectsList = combatItem.system.attackEffects.value.map(attackEffect => {
				let t = attackEffect.includes('-') ? attackEffect.split('-').join(' ') : attackEffect;
				return t;
			});
			const formattedEffects = attackEffectsList.map(effect =>
			  effect.split(" ").map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(" ")
			);

			const attackEffects = formattedEffects.length
				? ` plus ${formattedEffects.slice(0, -1).join(", ") + (formattedEffects.length > 1 ? ", and " : "") + formattedEffects.slice(-1)} `
				: " ";

			const isAgile = combatItem.system.traits.value.includes('agile');
			const penalty = isAgile ? 4 : 5;
			const secondPenalty = isAgile ? 8 : 10;

			const adjustedBonus = combatItem.system.bonus.value;
			const firstAdjustedBonus = adjustedBonus - penalty;
			const secondAdjustedBonus = adjustedBonus - secondPenalty;

			const damageString = dmgRolls.map(d => `${d.damage}${d.category === 'persistent' ? ' ' + d.category : ''} ${d.damageType}`).join(" + ");

			const description = combatItem.system.description.value
				? `\n{{paragraph: ${cleanHtmlTags(combatItem.system.description.value)}}}`
				: "";

						const combatText = `{{line **${isRanged ? "Ranged" : "Melee"}** ${actionTag('oneaction')} ${combatItem.name} ${formatBonus(adjustedBonus)} [${formatBonus(firstAdjustedBonus)}/${formatBonus(secondAdjustedBonus)}]${traits}, **Damage** ${damageString}${attackEffects}}}${description}`;

			return {
				text: combatText,
				isRanged,
				name: combatItem.name
			};
		}

		function formatBonus(bonus) {
			return `${bonus >= 0 ? '+' : ''}${bonus}`;
		}

		function getActionSymbol(action, actionSymbols) {
			let symbol = actionSymbols[action.system.actionType.value] || "";
			if (action.system.actionType.value === "action" && action.system.actions.value) {
				const actionCount = action.system.actions.value;
				symbol = actionCount === 2 ? actionTag('twoaction') : actionCount === 3 ? actionTag('threeaction') : symbol;
			}
			return symbol;
		}

		function formatActionText(action, actionSymbol) {
			let actionText = action.system.description.value;
			const actionTraits = action.system.traits.value.length ? ` \\(${action.system.traits.value.map(trait => {
				let modifiedTrait = trait.includes('-') ? trait.split('-').join(' ') : trait;
				return modifiedTrait;
			}).join(", ")})` : "";
			actionText = cleanHtmlTags(actionText);
			return `{{line **${action.name}** ${actionSymbol}${actionTraits} ${ actionText }}}`;
		}

		function cleanHtmlTags(htmlString) {
			// Remove weird Foundry formatting for tags
			htmlString = htmlString.replace(/ data-start="\d+" data-end="\d+"/g, "");
			
			// Replace <b> or <strong> tags with **text**
			htmlString = htmlString.replace(/<(b|strong)>(\s*)([\s\S]+?)(\s*)<\/\1>/gi, function (match, tag, leadingSpace, text, trailingSpace) {
				return `**${text.trim()}** `;
			});

			// Add space after the opening '**' if followed immediately by a non-space character
			htmlString = htmlString.replace(/(^|\s)(\*\*)(\S)/g, '$1$2 $3');

			// Add space before the closing '**' if preceded by a non-space character
			htmlString = htmlString.replace(/(\S)(\*\*)(\s|$)/g, '$1 $2$3');

			// Remove any other HTML tags
			htmlString = htmlString.replace(/<\/?[^>]+>/g, "");

			// Replace @@Damage[ ] with formatted string
			htmlString = htmlString.replace(
				/@@Damage\[\s*\(?\s*([^\s\[\]()]+)\s*\)?\s*(?:\[([a-zA-Z]+)\])?\s*\]/g,
				function(match, roll, type) { return type ? `${roll} ${type}` : roll; }
			);

			// Replace @@Check with formatted string
			htmlString = htmlString.replace(new RegExp("@@Check\\[(?:type:)?(\\w+)\\|dc:(\\d{2})(\\|basic(?::true)?)?\\]\\s*(save)?", "gi"), function (match, type, dc, basic) {
				return `DC ${dc} ${basic ? 'basic ' : ''}${type.charAt(0).toUpperCase() + type.slice(1)} save`;
			});

			// Replace @@Template with fomatted string
			htmlString = htmlString.replace(/@@Template\[(.*?)\]/g, function (match, p1) {
				let parts = p1.split("|");

				let formattedParts = parts.map(part => {
					let value = part.includes(':') ? part.split(':')[1] : part;
					let match = value.match(/(\d+)/);
					if (match) {
						return match[1] + "-foot";
					}
					return value;
				});

				return formattedParts.reverse().join(" ");
			});

			// Replace @@{} with content inside curly braces
			htmlString = htmlString.replace(/@@(\{[^}]*\})/g, "$1");

			// Remove @@[...] and similar patterns
			htmlString = htmlString.replace(/@@\w+\[[^\]]*\]/g, "");

			// Remove any remaining @@ followed by non-space characters
			htmlString = htmlString.replace(/@@[^\s{]+/g, "");

			// Remove braces, keeping the content inside
			htmlString = htmlString.replace(/{([^}]*)}/g, "$1");

			// Convert [[/r ...]] roll expressions to plain text
			htmlString = htmlString.replace(/\[\[\/r\s+([^\]]+)\]\]/g, "$1");

			// Remove double square brackets and their content
			htmlString = htmlString.replace(/\[\[[^\]]*\]\]/g, "");

			// Trim any unnecessary spaces inside **text**
			htmlString = htmlString.replace(/(\*\*)(\s*)(.*?)(\s*)(\*\*)/g, function (match, startBold, leadingSpace, text, trailingSpace, endBold) {
				return `${startBold}${text.trim()}${endBold}`;
			});

			// Add a space after every full stop if there isn't one
			htmlString = htmlString.replace(/\.([^\s])/g, '. $1');

			// Convert **bold** followed by non-bold text to a paragraph format
			htmlString = htmlString.replace(/(\*\*[^\*]+\*\*)([^*]+)/g, function (match, p1, p2, offset, string) {
				return offset === 0 ? p1 + p2 : `\n{{paragraph ${p1}${p2}}}`;
			});

			return htmlString;
		}


		function promptForFile() {
			let fileInput = document.createElement('input');
			fileInput.type = 'file';
			fileInput.accept = 'application/json';
			fileInput.onchange = e => {
				let file = e.target.files[0];
				if (!file) {
					return;
				}
				let reader = new FileReader();
				reader.onload = e => {
					try {
						let jsonData = JSON.parse(e.target.result);
						replaceContent(processJsonData(jsonData));
					} catch (error) {
						console.error('Error parsing JSON file:', error);
					}
				};
				reader.readAsText(file);
			};
			fileInput.click();
		}

		function promptForHomebrewery() {
			document.getElementById('homebreweryModal').classList.remove('hidden');

			if (navigator.clipboard?.readText) {
				navigator.clipboard.readText().then(text => {
					if (text) document.getElementById('homebreweryInput').value = text;
				}).catch(() => {});
			}
		}

		function closeHomebrewery() {
			document.getElementById('homebreweryInput').innerHTML = '';
			document.getElementById('homebreweryModal').classList.add('hidden');
		}

		function processFrontHomebreweryPage(page) {
			const title = (page.match(/^#\s+(.+)$/m) || [, ''])[1].trim();
			const bgUrl = (page.match(/!\[background image]\(([^)]+)\)/i) || [, ''])[1];
			const styleMatch = page.match(/!\[background image]\([^)]+\)\{([^}]+)\}/i);
			const styles = {};
			if (styleMatch) {
				styleMatch[1].split(',').forEach(s => {
					const [k, v] = s.split(':').map(x => x.trim());
					if (k && v) styles[k.toLowerCase()] = v;
				});
			}
			const addUnit = v => /^\d+(\.\d+)?$/.test(v) ? v + '%' : v;
			const width = addUnit(styles.width || 'auto');
			const height = addUnit(styles.height || '100');
			const posAttrs = ['left', 'top', 'right', 'bottom']
				.filter(p => styles[p])
				.map(p => `${p}=${addUnit(styles[p])}`);
			const author = (page.match(/\{\{banner\s+([^}]+)}}/i) || [, ''])[1].trim();
			if (!title || !bgUrl) return page;
			const imgAttrs = ['class=attach', `width=${width}`, `height=${height}`, ...posAttrs].join(', ');
			return [
				`{{image ${bgUrl}[${imgAttrs}]}}`,
				``,
				`{{title ${title}[position=absolute, bottom=74%, width=100%, font-size=76px, line-height=100%]}}`,
				``,
				`{{image https://i.imgur.com/W3kGupe.png[width=50%, position=absolute, left=50%, top=79%, transform=translateX(-50%), class=attach, height=auto]}}`,
				``,
				`{{title By ${author}[position=absolute, bottom=0%, width=100%, font-size=40px]}}`
			].join('\n\n');
		}

		function replaceFrames(page) {
			let usedFrame = false;
			return page.replace(/{{imageMaskEdge[\s\S]*?}}/g, (block) => {
				if (!usedFrame) {
					usedFrame = true;
					return `{{frame ${DEFAULT_FRAME}[mask-image=none,class=base,column-gap=27px]}}`;
				}
				return '';
			});
		}

		function convertMarkdownTables(page) {
			const lines = page.split(/\r?\n/);
			const out = [];
			for (let i = 0; i < lines.length; i++) {
				const line = lines[i];
				if (/^\|/.test(line)) {
					const tbl = [];
					while (i < lines.length && /^\|/.test(lines[i])) {
						tbl.push(lines[i++]);
					}
					i--;
					if (tbl.length >= 2 && /^\|\s*[-:]+/.test(tbl[1])) {
						const header = tbl[0].split('|').slice(1, -1).map(c => c.trim());
						const rows = tbl.slice(2).map(r => r.split('|').slice(1, -1).map(c => c.trim()));
						out.push(
							`{{table ${header.join(',')}`,
							...rows.map(r => r.join(',')),
							'}}'
						);
						continue;
					}
					out.push(...tbl);
					continue;
				}
				out.push(line);
			}
			return out.join('\n');
		}


		function get5eDC(level) {
			var prof = level >= 17 ? 6 : level >= 13 ? 5 : level >= 9 ? 4 : level >= 5 ? 3 : 2;
			var ability = level >= 8 ? 5 : level >= 4 ? 4 : 3;
			return 8 + prof + ability;
		}

		function convertDC(dndDC, level) {
			var expected5e = get5eDC(level);
			var pf2e = dcs[level] || dcs[20];
			var diff = dndDC - expected5e;
			if (Math.abs(diff) <= 10) {
				var steps = [-10, -5, -2, 0, 2, 5, 10];
				var closest = 0;
				var closestDist = Infinity;
				for (var i = 0; i < steps.length; i++) {
					var dist = Math.abs(diff - steps[i]);
					if (dist < closestDist) {
						closestDist = dist;
						closest = steps[i];
					}
				}
				diff = closest;
			}
			return pf2e + diff;
		}

		function convert5eSkills(text) {
			// Extract level from design section
			var levelMatch = text.match(/##\s*Design[\s\S]*?level\s+(\d+)/i);
			var level = levelMatch ? parseInt(levelMatch[1]) : null;

			var skillMap = {
				'Athletics': 'Athletics',
				'Acrobatics': 'Acrobatics',
				'Sleight of Hand': 'Thievery',
				'Stealth': 'Stealth',
				'Arcana': 'Arcana',
				'History': 'Society',
				'Investigation': 'Perception',
				'Nature': 'Nature',
				'Religion': 'Religion',
				'Animal Handling': 'Nature',
				'Insight': 'Perception',
				'Medicine': 'Medicine',
				'Perception': 'Perception',
				'Survival': 'Survival',
				'Deception': 'Deception',
				'Intimidation': 'Intimidation',
				'Performance': 'Performance',
				'Persuasion': 'Diplomacy'
			};
			var abilities = 'Strength|Dexterity|Constitution|Intelligence|Wisdom|Charisma';
			// Match patterns like "DC10 Wisdom (Insight)" or "DC 15 Charisma (Persuasion)"
			text = text.replace(
				new RegExp('DC\\s*(\\d+)\\s+(?:' + abilities + ')\\s+\\(([^)]+)\\)', 'gi'),
				function(match, dcNum, skill) {
					var trimmed = skill.trim();
					var mapped = null;
					for (var key in skillMap) {
						if (key.toLowerCase() === trimmed.toLowerCase()) {
							mapped = skillMap[key];
							break;
						}
					}
					if (!mapped) return match;
					var dc = parseInt(dcNum);
					if (level !== null) dc = convertDC(dc, level);
					return '\x00DC' + dc + ' ' + mapped;
				}
			);
			// Convert "Ability (Skill) check" without DC prefix (e.g. "Charisma (Performance) check")
			text = text.replace(
				new RegExp('(?:' + abilities + ')\\s+\\(([^)]+)\\)\\s+check', 'gi'),
				function(match, skill) {
					var trimmed = skill.trim();
					var mapped = null;
					for (var key in skillMap) {
						if (key.toLowerCase() === trimmed.toLowerCase()) {
							mapped = skillMap[key];
							break;
						}
					}
					if (!mapped) return match;
					return mapped + ' check';
				}
			);
			// Convert "X saving throw" to Pathfinder saves
			var saveMap = {
				'strength': 'Fortitude',
				'dexterity': 'Reflex',
				'constitution': 'Fortitude',
				'intelligence': 'Will',
				'wisdom': 'Will',
				'charisma': 'Will'
			};
			text = text.replace(
				new RegExp('DC\\s*(\\d+)\\s+(Strength|Dexterity|Constitution|Intelligence|Wisdom|Charisma)\\s+saving\\s+throw', 'gi'),
				function(match, dcNum, ability) {
					var dc = parseInt(dcNum);
					if (level !== null) dc = convertDC(dc, level);
					return '\x00DC' + dc + ' ' + saveMap[ability.toLowerCase()] + ' save';
				}
			);
			// Convert any remaining standalone DCs (e.g. "DC10" or "DC 15")
			if (level !== null) {
				text = text.replace(/(?<!\x00)DC\s*(\d+)/g, function(match, dcNum) {
					var dc = convertDC(parseInt(dcNum), level);
					return '\x00DC' + dc;
				});
			}
			// Strip placeholder markers
			text = text.replace(/\x00DC/g, 'DC');
			return text;
		}

		function handleHomebrewery() {
			let text = document.getElementById('homebreweryInput').value;
			document.getElementById('homebreweryInput').innerHTML = '';
			closeHomebrewery();
			text = text.replace(/\\column/g, '{{columnbreak}}');
			text = text.replace(/\{\{break\}\}/g, '');
			text = convert5eSkills(text);
			let pages = text.split('\\page');

			// Extract title from the first page
			var title = (pages[0].match(/^#\s+(.+)$/m) || [, ''])[1].trim();

			pages[0] = processFrontHomebreweryPage(pages[0]);
			pages = pages.map(replaceFrames);
			pages = pages.map(convertMarkdownTables);
			pages[pages.length - 1] = getCreditsPage(title);
			pages = pages.join('{{pagebreak}}');
			pages = pages.replace(/(\r?\n\s*){3,}/g, '\n');
			editor.setValue(pages);

		}

		function replacePlaceholders(placeholder, page, wrapper, pageNumber) {
			// Remember that classes need to be in a list, even if only one element
			const regex = /([a-zA-Z]+)(:*)([\s\S]*?)(?:\[(.*?)\])?$/g;
			const elements = paragraphElements;
			placeholder = placeholder.replace(regex, function (match, elementName, indentMarkers, content, attributes) {
				let margin = indentMarkers.length;

				let element = elements[elementName];
				if (element === undefined) {
					return match;
				}

				let newElement;
				let shouldAttach = false;
				const hasBlockContent = element["html"] === "p" && /<(p|div|table|h[1-6])\b/.test(content);
				if (element["html"]) {
					newElement = document.createElement(hasBlockContent ? "div" : element["html"]);
				}
				if (element["src"] !== undefined) {
					newElement.src = element["src"];
				}
				else if (element["html"] === "img") {
					newElement.src = content.trim();
				}
				else if (elementName === "mask") {
					const imageElement = document.createElement('img');
					imageElement.classList.add('image');
					imageElement.src = content.trim();
					newElement.appendChild(imageElement);
					newElement.classList.add('mask-base');
					shouldAttach = true;
				}
				else if (elementName === "table") {
					const rows = content.trim().split('\n');
					const headers = rows[0].split(/,(?! )/).map(header => header.trim());

					const tbody = document.createElement('tbody');
					const thead = document.createElement('thead');
					const headerRow = document.createElement('tr');

					headers.forEach(header => {
						const th = document.createElement('th');
						th.innerHTML = header;
						headerRow.appendChild(th);
					});
					thead.appendChild(headerRow);
					newElement.appendChild(thead);

					for (let i = 1; i < rows.length; i++) {
						const row = document.createElement('tr');
						rows[i].split(/,(?! )/).map(cell => cell.trim()).forEach(cellValue => {
							const td = document.createElement('td');
							td.innerHTML = cellValue;
							row.appendChild(td);
						});
						tbody.appendChild(row);
					}
					newElement.appendChild(tbody);
				}
				else {
					newElement.innerHTML = content.trim();
					if (hasBlockContent) {
						const children = Array.from(newElement.childNodes);
						const fragment = document.createDocumentFragment();
						const blockTags = new Set(['P', 'DIV', 'TABLE', 'H1', 'H2', 'H3', 'H4', 'H5', 'H6']);
						let inlineGroup = [];

						function flushInline() {
							if (inlineGroup.length && inlineGroup.some(n => n.textContent.trim())) {
								const p = document.createElement('p');
								element["classes"]?.forEach(cls => p.classList.add(cls));
								inlineGroup.forEach(n => p.appendChild(n));
								fragment.appendChild(p);
							}
							inlineGroup = [];
						}

						for (const child of children) {
							if (child.nodeType === Node.ELEMENT_NODE && blockTags.has(child.tagName)) {
								flushInline();
								fragment.appendChild(child);
							} else {
								inlineGroup.push(child);
							}
						}
						flushInline();

						newElement.innerHTML = '';
						newElement.appendChild(fragment);
					}
				}

				element["classes"]?.forEach(className => {
					newElement.classList.add(className);
				});

				let maskX = 0;
				let maskY = 0; 
				let maskWidth = 100; 
				let maskHeight = 100;
				let imageX = 0; 
				let imageY = 0; 
				let imageWidth = 100;
				let imageHeight = 100;

				const assignMap = {
				  'mask-x': val => maskX = val,
				  'mask-y': val => maskY = val,
				  'mask-width': val => maskWidth = val,
				  'mask-height': val => maskHeight = val,
				  'image-x': val => imageX = val,
				  'image-y': val => imageY = val,
				  'image-width': val => imageWidth = val,
				  'image-height': val => imageHeight = val
				};

				if (newElement && attributes) {
					const attrs = attributes.split(/,(?![^()]*\))/).map(attr => attr.trim().split('='));
					attrs.forEach(([key, value]) => {
						if (key === "class" && value === "attach") {
							shouldAttach = true
						}
						else if (key === "class" && value) {
							newElement.classList.add(value);
						}
						else if (elementName === "table" && key === "headerBackground") {
							newElement.style.setProperty('--header-bg-color', value);
						}
						else if (elementName === "table" && key === "headerColor") {
							newElement.style.setProperty('--header-color', value);
						}
						else if ((elementName === "title" || elementName === "section" || elementName === "subsection") && key === "text-shadow") {
							newElement.style.setProperty("text-shadow", `-3px -3px 0 ${value}, 0px -3px 0 ${value}, 3px -3px 0 ${value}, -3px 0px 0 ${value}, 3px 0px 0 ${value}, -3px 3px 0 ${value}, 0px 3px 0 ${value}, 3px 3px 0 ${value}, -2px -2px 0 ${value}, 2px -2px 0 ${value}, -2px 2px 0 ${value}, 2px 2px 0 ${value}`);
						}
						else if (key in assignMap) {
							if (value != null) {
								value = value.replace('%', '');
								assignMap[key](value);
							}
						}
						else {
							if (elementName === "mask") {
								if (key === "z-index") {
									newElement.style[key] = value;
								}
								else {
									newElement.firstElementChild.style[key] = value;
								}
							}
							else {
								newElement.style[key] = value;
							}
							
						}

						if (elementName === "mask") {
							shouldAttach = true
						}
					});

					if (newElement.style.getPropertyValue('-webkit-text-fill-color') === 'transparent') {
						newElement.style.setProperty('-webkit-text-stroke-width', '0px');
					}
				}

				if (elementName === "mask") {
					maskX = parseFloat(maskX);
					maskY = parseFloat(maskY);
					maskWidth = parseFloat(maskWidth);
					maskHeight = parseFloat(maskHeight);

					maskX = ((maskX + ((100-maskWidth)/2)) / 100) * PAGE_W_PX;
					maskY = ((maskY + ((100-maskHeight)/2)) / 100) * PAGE_H_PX;

					maskWidth = maskWidth/100 * PAGE_W_PX;
					maskHeight = maskHeight/100 * PAGE_H_PX;
					newElement.style.setProperty(
					"mask-position",
					`${maskX}px ${maskY}px`
					);
					newElement.style.setProperty("mask-size", `${maskWidth}px ${maskHeight}px`)
					const imageElement = newElement.firstElementChild;
					if (imageElement) {
						imageX = parseFloat(imageX);
						imageY = parseFloat(imageY);
						imageWidth = parseFloat(imageWidth);
						imageHeight = parseFloat(imageHeight);

						imageX = ((imageX + ((100-imageWidth)/2)) / 100) * PAGE_W_PX;
						imageY = ((imageY + ((100-imageHeight)/2)) / 100) * PAGE_H_PX;

						imageWidth = imageWidth/100 * PAGE_W_PX;
						imageHeight = imageHeight/100 * PAGE_H_PX;

						imageElement.style.position  = 'absolute';
						imageElement.style.left      = `${imageX}px`;
						imageElement.style.top       = `${imageY}px`;
						imageElement.style.width     = `${imageWidth}px`;
						imageElement.style.height    = `${imageHeight}px`;
					}
				}

				if (elementName === "frame") {
					const [imgSrc, pageName = "page"] = content.trim().split(",").map(s => s.trim());

					const pageElement = document.createElement(element.html);
					pageElement.src = `../assets/${pageName}.png`;
						
					wrapper.style.margin = `${parseFloat(newElement.style.padding) + 0.5}cm`;
					wrapper.style.columnGap = newElement.style.columnGap;
					const marginInMM = (parseFloat(newElement.style.padding) + 0.5) * 10;
					newElement.src = imgSrc;
					newElement.style.padding = 0;
					newElement.classList.add(elementName);

					page.appendChild(pageElement);
					page.appendChild(newElement);

					wrapper.style.width = `${210 - 2 * marginInMM}mm`;
					wrapper.style.height = `${297 - 2 * marginInMM}mm`;

					newElement = '';
				}

				if (elementName == "pagenumber") {
					newElement.innerHTML = pageNumber;
					const offset = fileStyles.pageNumberOffset ?? 50;
					const flipped = fileStyles.pageNumberFlipped ?? false;
					const isOdd = pageNumber % 2 === 1;
					const useLeft = flipped ? !isOdd : isOdd;
					if (useLeft) {
						newElement.style.left = `${offset}%`;
					} else {
						newElement.style.right = `${offset}%`;
					}
				}


				if (elementName === "dc") {
					newElement.innerHTML = 'DC ' + dcs[content.trim()];
				}

				if (/^:+$/g.test(content.trim())) {
					const breaksCount = (content.match(/:/g) || []).length;
					newElement.innerHTML = '';
					newElement.classList = [];
					for (let i = 0; i < breaksCount; i++) {
						newElement.appendChild(document.createElement("br"));

					}
				}

				if (margin > 0) {
					newElement.style.marginLeft = `${margin}em`;
				}

				if (shouldAttach) {
					page.appendChild(newElement);
					newElement = null;
				}

				return newElement ? newElement.outerHTML : "";
			});

			return placeholder;
		}

		function replaceBrackets(text, page, wrapper, pageNumber) {
			text = text.replace(/<\/?p>/g, "");
			let index = 0;
			function processSegment() {
				let content = '';
				while (index < text.length) {
					if (text[index] === '{' && text[index + 1] === '{') {
						index += 2;
						content += processSegment();
					} else if (text[index] === '}' && text[index + 1] === '}') {
						index += 2;
						return replacePlaceholders(content, page, wrapper, pageNumber);
					} else {
						content += text[index++];
					}
				}
				return content;
			}
			text = processSegment()
			let lines = text.split('\n');
			let processedLines = lines.map(line => {
				if (line.trim() === "" || (line.startsWith('<') && !line.startsWith('<strong') && !line.startsWith('<b') && !line.startsWith('<em') && !line.startsWith('<i'))) {
					return line;
				} else {
					return replacePlaceholders("paragraph " + line, page, wrapper, pageNumber);
				}
			});
			return processedLines.join('\n');
		}

		function applyClasses(content, selectors, className) {
			selectors.forEach(selector => {
				content.querySelectorAll(selector).forEach(element => {
					element.classList.add(className);
				});
			});

		}

		function createElementWithClass(tagName, className) {
			const element = document.createElement(tagName);
			element.classList.add(className);
			return element;
		}

		const TOC_ENTRIES_PER_COLUMN = 28;

		function collectTitles(rawText) {
			const pages = rawText.split("{{pagebreak}}");
			const titles = [];
			let firstTitleSkipped = false;

			for (let i = 0; i < pages.length; i++) {
				const tagRegex = /\{\{(section|subsection|title)\s+([\s\S]*?)(?:\[(.*?)\])?\s*\}\}/g;
				let match;
				while ((match = tagRegex.exec(pages[i])) !== null) {
					const type = match[1];
					const text = match[2].trim();
					const attrs = match[3] || "";

					if (type === "title" && !firstTitleSkipped && i === 0) {
						firstTitleSkipped = true;
						continue;
					}

					if (/toc\s*=\s*false/i.test(attrs)) {
						continue;
					}

					titles.push({ type, text, originalPageIndex: i });
				}
			}
			return titles;
		}

		function buildTocEntries(titles, tocInsertIndex, tocPageCount) {
			const entries = [];
			for (const t of titles) {
				let pageNum = t.originalPageIndex + 1;
				if (t.originalPageIndex > tocInsertIndex) {
					pageNum += tocPageCount - 1;
				}
				const cls = t.type === "section" ? "toc-section"
						: t.type === "subsection" ? "toc-subsection"
						: "toc-entry";
				entries.push({
					type: t.type,
					html: `<div class="${cls}">` +
						`<span class="toc-text">${t.text}</span>` +
						`<span class="toc-dots"></span>` +
						`<span class="toc-page">${pageNum}</span>` +
						`</div>`
				});
			}
			return entries;
		}

		function packTocColumns(entries, entriesPerCol) {
			const columns = [];
			for (let i = 0; i < entries.length; i += entriesPerCol) {
				columns.push(entries.slice(i, i + entriesPerCol));
			}
			return columns;
		}

		function generateTocPages(titles, tocInsertIndex, tocPageCount, entriesPerCol, topSpacing, tocCols) {
			entriesPerCol = entriesPerCol || TOC_ENTRIES_PER_COLUMN;
			topSpacing = topSpacing || 0;
			tocCols = tocCols || 2;
			if (titles.length === 0) return "";

			const entries = buildTocEntries(titles, tocInsertIndex, tocPageCount);
			const columns = packTocColumns(entries, entriesPerCol);

			const spacer = topSpacing > 0 ? `{{paragraph ${":".repeat(topSpacing)}}}\n\n` : "";
			const tocMarker = '<div class="toc-marker" style="display:none"></div>\n';
			const tocPages = [];
			for (let i = 0; i < columns.length; i += tocCols) {
				const pageCols = columns.slice(i, i + tocCols);
				const colHtmls = pageCols.map(col =>
					spacer + col.map(e => e.html).join("\n")
				);
				tocPages.push(tocMarker + colHtmls.join("\n{{columnbreak}}\n"));
			}
			return tocPages.join("\n{{pagebreak}}\n");
		}

		function updateTocStyle() {
			const tocCols = fileStyles.tocColumns ?? 2;
			tocDynamicStyle.textContent = `:host {` +
				`--toc-section-color: ${fileStyles.tocSectionColor ?? '#58180D'};` +
				`--toc-subsection-color: ${fileStyles.tocSubsectionColor ?? '#58180D'};` +
				`--toc-title-color: ${fileStyles.tocTitleColor ?? '#333333'};` +
				`--toc-dot-color: ${fileStyles.tocDotColor ?? '#999999'};` +
				`--toc-section-pagenum-color: ${fileStyles.tocSectionPageNumColor ?? '#58180D'};` +
				`--toc-subsection-pagenum-color: ${fileStyles.tocSubsectionPageNumColor ?? '#58180D'};` +
				`--toc-title-pagenum-color: ${fileStyles.tocTitlePageNumColor ?? '#58180D'};` +
				`--toc-section-size: ${fileStyles.tocSectionSize ?? 24}px;` +
				`--toc-subsection-size: ${fileStyles.tocSubsectionSize ?? 18}px;` +
				`--toc-title-size: ${fileStyles.tocTitleSize ?? 12}px;` +
				`--toc-section-pagenum-size: ${fileStyles.tocSectionPageNumSize ?? 24}px;` +
				`--toc-subsection-pagenum-size: ${fileStyles.tocSubsectionPageNumSize ?? 18}px;` +
				`--toc-title-pagenum-size: ${fileStyles.tocTitlePageNumSize ?? 12}px;` +
				`}\n` +
				`.page.toc-page, .page.toc-page .columnWrapper { column-count: ${tocCols}; }`;
		}

		function updateTocLive() {
			const htmlContent = editor.getValue();
			const contentsMatch = htmlContent.match(/\{\{contents\s*\}\}/);
			if (!contentsMatch) return;

			const tocCols = fileStyles.tocColumns ?? 2;
			const entriesPerCol = fileStyles.tocDensity ?? TOC_ENTRIES_PER_COLUMN;
			const topSpacing = fileStyles.tocSpacing ?? 0;

			const titles = collectTitles(htmlContent);
			const pageSegments = htmlContent.split("{{pagebreak}}");
			const tocInsertIndex = pageSegments.findIndex(s => s.includes(contentsMatch[0]));
			const tocPageCount = titles.length > 0 ? Math.max(1, Math.ceil(titles.length / (entriesPerCol * tocCols))) : 0;

			const entries = buildTocEntries(titles, tocInsertIndex, tocPageCount);
			const columns = packTocColumns(entries, entriesPerCol);

			const spacer = topSpacing > 0 ? `<p>${'<br>'.repeat(topSpacing)}</p>` : '';
			const colBreak = '<div class="break"></div>';

			const tocPagesHtml = [];
			for (let i = 0; i < columns.length; i += tocCols) {
				const pageCols = columns.slice(i, i + tocCols);
				const colHtmls = pageCols.map(col =>
					spacer + col.map(e => e.html).join('')
				);
				tocPagesHtml.push(colHtmls.join(colBreak));
			}

			// Update only TOC entries within toc-page elements, preserving other content
			const tocPages = shadow.querySelectorAll('.page.toc-page');
			tocPages.forEach((page, idx) => {
				const cw = page.querySelector('.columnWrapper');
				if (cw && tocPagesHtml[idx] !== undefined) {
					// Remove TOC-specific elements and layout elements from previous render
					cw.querySelectorAll('.toc-section, .toc-subsection, .toc-entry, .toc-marker, .break').forEach(el => el.remove());
					// Remove spacer paragraphs (bare <p> with only <br> children)
					cw.querySelectorAll('p').forEach(el => {
						if (el.classList.length === 0 && el.children.length > 0 && Array.from(el.children).every(c => c.tagName === 'BR')) {
							el.remove();
						}
					});
					// Insert new TOC HTML at the end of the columnWrapper
					cw.insertAdjacentHTML('beforeend', tocPagesHtml[idx]);
				}
			});

			// Update CSS variables + column count + top spacing
			updateTocStyle();
		}

		let cachedTocHtml = null;

		function rebuildToc() {
			const htmlContent = editor.getValue();
			const contentsMatch = htmlContent.match(/\{\{contents\s*\}\}/);
			if (!contentsMatch) {
				cachedTocHtml = null;
				tocDynamicStyle.textContent = '';
				return;
			}
			const tocCols = fileStyles.tocColumns ?? 2;
			const entriesPerCol = fileStyles.tocDensity ?? TOC_ENTRIES_PER_COLUMN;
			const topSpacing = fileStyles.tocSpacing ?? 0;
			const titles = collectTitles(htmlContent);
			const pageSegments = htmlContent.split("{{pagebreak}}");
			const tocInsertIndex = pageSegments.findIndex(s => s.includes(contentsMatch[0]));
			// Two-pass: estimate page count, pack, then correct if actual differs
			let tocPageCount = titles.length > 0 ? Math.max(1, Math.ceil(titles.length / (entriesPerCol * tocCols))) : 0;
			for (let pass = 0; pass < 3; pass++) {
				const entries = buildTocEntries(titles, tocInsertIndex, tocPageCount);
				const columns = packTocColumns(entries, entriesPerCol);
				const actualPages = Math.max(1, Math.ceil(columns.length / tocCols));
				if (actualPages === tocPageCount) break;
				tocPageCount = actualPages;
			}
			cachedTocHtml = generateTocPages(titles, tocInsertIndex, tocPageCount, entriesPerCol, topSpacing, tocCols);
			updateTocStyle();
			cachedPageTexts = [];
		}

		function displayChange() {
			let htmlContent = editor.getValue();

			const contentsMatch = htmlContent.match(/\{\{contents\s*\}\}/);
			if (contentsMatch) {
				if (cachedTocHtml === null) rebuildToc();
				htmlContent = htmlContent.replace(contentsMatch[0], cachedTocHtml);
				updateTocStyle();
			} else {
				tocDynamicStyle.textContent = '';
			}

			let pageTexts = htmlContent.split("\{\{pagebreak\}\}");
			let existingPages = shadow.querySelectorAll('.page');

			for (let i = existingPages.length - 1; i >= pageTexts.length; i--) {
				shadow.removeChild(existingPages[i]);
			}

			for (let i = 0; i < pageTexts.length; i++) {
				if (cachedPageTexts[i] === pageTexts[i]) {
					continue;
				}

				let page;
				if (i < existingPages.length) {
					page = existingPages[i];
					page.innerHTML = '';
				} else {
					page = createElementWithClass("div", "page");
					shadow.insertBefore(page, pageStyle);
				}

				let pageNumber = i + 1;
				let columnWrapper = createElementWithClass("div", "columnWrapper");
				let html = converter.makeHtml(pageTexts[i]);
				columnWrapper.innerHTML = replaceBrackets(html, page, columnWrapper, pageNumber);
				applyClasses(columnWrapper, ["h1", "subtitle"], "wide");
				columnWrapper.innerHTML = columnWrapper.innerHTML.replace(/<p><\/p>|}}/gm, "");
				columnWrapper.querySelectorAll('a[href*="open5e.com"]').forEach(function(a) {
					a.style.backgroundColor = 'red';
				});
				page.appendChild(columnWrapper);

				const tocMarkerEl = columnWrapper.querySelector('.toc-marker');
				if (tocMarkerEl) {
					page.classList.add('toc-page');
					tocMarkerEl.remove();
				} else {
					page.classList.remove('toc-page');
				}
			}

			cachedPageTexts = pageTexts;
		}

		function animateSaving() {
			let saveButton = document.getElementById('save');
			if (!saveButton.disabled) {
				saveButton.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Saving...';
				rebuildToc();
				displayChange();
				saveDocument();
				setTimeout(() => {
					saveButton.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Saved';
					saveButton.disabled = true;
				}, 500);
			}
		}

		async function saveDocument() {
			let content = editor.getValue();
			const r = await fetch("/api/files/" + documentId, {
						method: "PUT",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({ content: content, styles: JSON.stringify(fileStyles) })
					});
		}

		async function getDocument() {
			let row = await fetch("/api/files/" + documentId, { headers: { Accept: "application/json" } });
			row = await row.json();
			editor.setValue(row.content);
			editor.clearHistory();
			applyStyles(row.styles || '{}');
		}

		async function printDocument() {
			saveDocument();

			// Rasterize masked elements to canvas so they survive print-to-PDF
			var maskImageMap = {
				'mask-center': '/assets/center.webp',
				'mask-edge': '/assets/edge.webp',
				'mask-center-round': '/assets/center-round.png',
				'mask-center-square': '/assets/center-square.png'
			};

			function loadImg(src) {
				return new Promise(function(resolve) {
					var img = new Image();
					img.crossOrigin = 'anonymous';
					img.onload = function() { resolve(img); };
					img.onerror = function() { resolve(null); };
					img.src = src;
				});
			}

			var maskElements = shadow.querySelectorAll('.mask-base');
			var replacements = [];

			for (var i = 0; i < maskElements.length; i++) {
				var maskEl = maskElements[i];
				var page = maskEl.closest('.page');
				if (!page) continue;
				var pageW = page.offsetWidth;
				var pageH = page.offsetHeight;

				var maskUrl = null;
				for (var cls in maskImageMap) {
					if (maskEl.classList.contains(cls)) {
						maskUrl = maskImageMap[cls];
						break;
					}
				}
				if (!maskUrl) continue;

				var contentImgEl = maskEl.querySelector('img');
				if (!contentImgEl) continue;

				var cs = window.getComputedStyle(maskEl);
				var mpRaw = cs.getPropertyValue('mask-position') || cs.getPropertyValue('-webkit-mask-position');
				var msRaw = cs.getPropertyValue('mask-size') || cs.getPropertyValue('-webkit-mask-size');

				var mpParts = mpRaw ? mpRaw.split(/\s+/).map(parseFloat) : [pageW * 0.5, pageH * 0.5];
				var msParts = msRaw && msRaw !== '100%' ? msRaw.split(/\s+/).map(parseFloat) : [pageW, pageH];

				var imgs = await Promise.all([loadImg(maskUrl), loadImg(contentImgEl.src)]);
				var maskImg = imgs[0], contentImg = imgs[1];
				if (!maskImg || !contentImg) continue;

				var canvas = document.createElement('canvas');
				canvas.width = pageW;
				canvas.height = pageH;
				var ctx = canvas.getContext('2d');

				ctx.drawImage(maskImg, mpParts[0], mpParts[1], msParts[0], msParts[1]);
				ctx.globalCompositeOperation = 'source-in';
				ctx.drawImage(contentImg,
					parseFloat(contentImgEl.style.left),
					parseFloat(contentImgEl.style.top),
					parseFloat(contentImgEl.style.width),
					parseFloat(contentImgEl.style.height)
				);

				try {
					var dataUrl = canvas.toDataURL('image/png');
					var replacement = document.createElement('img');
					replacement.src = dataUrl;
					replacement.style.cssText = 'position:absolute;top:0;left:0;width:' + pageW + 'px;height:' + pageH + 'px;z-index:' + (maskEl.style.zIndex || 10) + ';';
					replacements.push({ parent: maskEl.parentNode, maskEl: maskEl, replacement: replacement });
					maskEl.parentNode.replaceChild(replacement, maskEl);
				} catch(e) {
					// Canvas tainted by cross-origin image, skip rasterization
				}
			}

			var links = '';
			document.querySelectorAll('head link[rel="stylesheet"]').forEach(function(link) {
				if (!link.href.endsWith('/css/site.css')) {
					links += '<link rel="stylesheet" href="' + link.href + '" />';
				}
			});

			var pageRule = String.fromCharCode(64) + 'page { size: 210mm 297mm; margin: 0; }';
			var printCSS = '<style>' + pageRule + '\n' +
				'html { margin: 0!important; height: auto!important; overflow: auto!important; }\n' +
				'body { margin: 0!important; height: 100%!important; overflow: auto!important; }\n' +
				'.page { margin: 0!important; box-shadow: none!important; page-break-after: always; }\n' +
				'.page:last-child { page-break-after: avoid; }\n' +
				'a { color: #0000EE!important; text-decoration: underline!important; }\n' +
				'ul { display: block; list-style-type: disc; margin-block-start: 1em; margin-block-end: 1em; padding-inline-start: 40px; unicode-bidi: isolate; }\n' +
				'<\/style>';

			var html = '<!DOCTYPE html><html><head>' + links + printCSS +
				'<\/head><body>' + shadow.innerHTML + '<\/body><\/html>';

			// Restore original mask elements in the live DOM
			for (var j = 0; j < replacements.length; j++) {
				var r = replacements[j];
				r.parent.replaceChild(r.maskEl, r.replacement);
			}

			var printWindow = window.open('', '_blank');
			printWindow.document.open();
			printWindow.document.writeln(html);
			printWindow.document.close();

			printWindow.onload = function() {
				printWindow.focus();
				printWindow.print();
			};
		}

		const config = { minColumnWidth: 200, resizerSelector: ".resizer", mainSectionSelector: "section" };
		const state = { isResizing: false, initialX: null, initialWidths: null };
		const elements = {
			resizer: document.querySelector(config.resizerSelector),
			main: document.querySelector(config.mainSectionSelector)
		};

		elements.resizer.addEventListener("mousedown", e => {
			state.isResizing = true;
			state.initialX = e.clientX;
			state.initialWidths = getInitialWidths();
			document.addEventListener("mousemove", onMouseMove);
			document.addEventListener("mouseup", onMouseUp);
		});

		function getInitialWidths() {
			const styles = getComputedStyle(elements.main);
			const columns = styles.gridTemplateColumns.split(" ");
			return [parseInt(columns[0]), parseInt(columns[2])];
		}

		function onMouseMove(e) {
			if (!state.isResizing) return;
			const deltaX = e.clientX - state.initialX;
			const [newLeftWidth, newRightWidth] = updateWidths(deltaX);
			elements.main.style.gridTemplateColumns = `${newLeftWidth}px 20px ${newRightWidth}px`;
		}

		function updateWidths(deltaX) {
			let newLeftWidth = state.initialWidths[0] + deltaX;
			let newRightWidth = state.initialWidths[1] - deltaX;
			if (newLeftWidth < config.minColumnWidth) {
				newLeftWidth = config.minColumnWidth;
				newRightWidth = state.initialWidths[0] + state.initialWidths[1] - config.minColumnWidth;
			} else if (newRightWidth < config.minColumnWidth) {
				newRightWidth = config.minColumnWidth;
				newLeftWidth = state.initialWidths[0] + state.initialWidths[1] - config.minColumnWidth;
			}
			return [newLeftWidth, newRightWidth];
		}

		function onMouseUp() {
			state.isResizing = false;
			document.removeEventListener("mousemove", onMouseMove);
			document.removeEventListener("mouseup", onMouseUp);
		}

		function fillDropdownContent() {
			const elementsContainer = document.querySelector('.dropdownContainer');
			for (const [key, value] of Object.entries(paragraphElements)) {
				const button = document.createElement('button');
				button.textContent = key.charAt(0).toUpperCase() + key.slice(1);
				button.onclick = () => applyElement(key);
				elementsContainer.appendChild(button);
			}
			populateStyleMenu();
			const buttons = document.querySelectorAll(".dropdownButton");
			const targets = document.querySelectorAll(".dropdownContainer");
			buttons.forEach((button, index) => {
				const target = targets[index];
				button.addEventListener("click", function () {
					target.classList.toggle("visible");
					target.classList.toggle("hidden");
				});
			});
		}

		function applyElement(key) {
			const selectedText = editor.getSelection();
			const cursorPos = editor.getCursor();
			if (paragraphElements[key].special) {
				const newText = `{{${key}}}`;
				editor.replaceRange(newText, {
					line: cursorPos.line,
					ch: 0
				});
				const newCursorPos = {
					line: cursorPos.line,
					ch: 0
				};
				editor.setCursor(newCursorPos);
			}
			else if (selectedText) {
				const regex = /\{\{(.+?) (.+?)\}\}/g;
				let newText;

				if (regex.test(selectedText)) {
					newText = selectedText.replace(regex, `{{${key} $2}}`);
				} else {
					newText = `{{${key} ${selectedText}}}`;
				}

				const startPos = editor.getCursor("from");
				const endPos = editor.getCursor("to");

				editor.replaceSelection(newText);

				const newLines = newText.split('\n');
				const newEndLine = startPos.line + newLines.length - 1;
				const newEndCh = (newLines.length === 1) ?
					startPos.ch + newText.length :
					newLines[newLines.length - 1].length;

				const newEndPos = {
					line: newEndLine,
					ch: newEndCh
				};
				editor.setSelection(startPos, newEndPos);
			}
		}

		function scrollToPart(mode) {
			const doc = editor.getDoc()
			const pageBreaks = []
			let tocSourcePage = -1
			let sourcePageIdx = 0
			doc.eachLine(l => {
				if (l.text.includes("{{contents}}")) tocSourcePage = sourcePageIdx;
				if (l.text.includes("{{pagebreak}}")) {
					pageBreaks.push(doc.getLineNumber(l));
					sourcePageIdx++;
				}
			})
			const host = document.getElementById('displayAreaHolder')
			const pages = host.shadowRoot.querySelectorAll('.page')
			const tocExtra = (tocSourcePage >= 0 && cachedTocHtml)
				? (pages.length - pageBreaks.length - 1)
				: 0;

			if (mode === 'editor') {
				let idx = pages.length, closest = Number.MAX_VALUE
				pages.forEach((p, i) => {
					const ratio = Math.abs(p.getBoundingClientRect().top / p.clientHeight)
					if (ratio < closest) { closest = ratio; idx = i }
				})
				if (idx === 0) { editor.scrollTo(null, 0); return }
				// Map rendered page index to source page break index
				let srcIdx = idx - 1;
				if (tocExtra > 0 && idx > tocSourcePage) {
					if (idx <= tocSourcePage + tocExtra) {
						// Inside a TOC page — scroll to the contents tag source line
						srcIdx = tocSourcePage > 0 ? tocSourcePage - 1 : 0;
					} else {
						srcIdx = idx - 1 - tocExtra;
					}
				}
				if (srcIdx < 0 || srcIdx >= pageBreaks.length) return
				const line = pageBreaks[srcIdx]
				const { top } = editor.charCoords({ line, ch: 0 }, 'local')
				editor.scrollTo(null, top)
			} else {
				const top = editor.getScrollInfo().top
				let idx = 0, dist = Number.MAX_VALUE
				for (let i = 0; i < pageBreaks.length; i++) {
					const line = pageBreaks[i];
					const { top: lineTop } = editor.charCoords({ line, ch: 0 }, 'local');
					if (i === 0 && top - lineTop < 0) {
						idx = 0;
						break;
					}
					const d = lineTop - top;
					if (d > 0) {
						dist = d;
						idx = i;
						break;
					}
					idx = pageBreaks.length;
				}
				// Map source page index to rendered page index
				let renderIdx = idx;
				if (tocExtra > 0 && idx >= tocSourcePage) {
					renderIdx = idx + tocExtra;
				}
				if (renderIdx < 0 || renderIdx >= pages.length) return
				pages[renderIdx].scrollIntoView()
			}
		}


		window.onload = (event) => {
			localStorage.setItem("PathBinder-Scroll", 0);
			fillDropdownContent()
			getDocument();
		};

		document.addEventListener('keydown', function (event) {
			if ((event.ctrlKey || event.metaKey) && event.key === 's') {
				event.preventDefault();
				animateSaving();
			}
		});
</script>